# lx build. Invoked from the repository root Makefile, or directly:
#   make -C source
# Platform-specific sources are selected by uname; everything else is
# plain C99 + the standard library.

BUILD   ?= ../build
CC      ?= cc
OPT     ?= -O2
CSTD    := -std=c99
WARN    := -Wall -Wextra
PREFIX  ?= /usr/local

UNAME_S := $(shell uname -s 2>/dev/null || echo unknown)

CORE := main.c util.c tstamp.c template.c filter.c logfile.c ui.c wizard.c

# Windows: MSYS2/MinGW shells report MINGW*_NT / MSYS_NT in uname;
# native mingw32-make has no uname but sets OS=Windows_NT. Cygwin is
# deliberately NOT matched - its gcc provides POSIX APIs (termios,
# select) and does not define _WIN32, so it uses the generic POSIX
# backend below.
ifneq (,$(findstring MINGW,$(UNAME_S))$(findstring MSYS,$(UNAME_S)))
  TARGET_OS := windows
else ifeq ($(UNAME_S),unknown)
  ifeq ($(OS),Windows_NT)
    TARGET_OS := windows
  endif
endif

ifeq ($(TARGET_OS),windows)
  PLAT := windows/term_windows.c windows/fswatch_windows.c \
          windows/pipein_windows.c
  DEFS :=
  EXE  := .exe
else ifeq ($(UNAME_S),Darwin)
  PLAT := posix/term_posix.c posix/pipein_posix.c darwin/fswatch_darwin.c
  DEFS := -D_DARWIN_C_SOURCE
else ifeq ($(UNAME_S),Linux)
  PLAT := posix/term_posix.c posix/pipein_posix.c linux/fswatch_linux.c
  DEFS := -D_POSIX_C_SOURCE=200809L -D_DEFAULT_SOURCE
else
  PLAT := posix/term_posix.c posix/pipein_posix.c posix/fswatch_poll.c
  DEFS := -D_POSIX_C_SOURCE=200809L
endif

BIN := $(BUILD)/lx$(EXE)

SRC := $(CORE) $(PLAT)
OBJ := $(SRC:%.c=$(BUILD)/obj/%.o)
LIBOBJ := $(filter-out $(BUILD)/obj/main.o,$(OBJ))

TESTS := test_tstamp test_template test_filter test_logfile test_wizard
TESTBIN := $(TESTS:%=$(BUILD)/tests/%)

all: $(BIN)

$(BIN): $(OBJ)
	@mkdir -p $(BUILD)
	$(CC) $(OBJ) -o $@

$(BUILD)/obj/%.o: %.c
	@mkdir -p $(dir $@)
	$(CC) $(CSTD) $(WARN) $(OPT) $(DEFS) -I. -MMD -MP -c $< -o $@

# header dependency tracking generated by -MMD
-include $(OBJ:.o=.d)

$(BUILD)/tests/%: ../tests/%.c $(LIBOBJ)
	@mkdir -p $(BUILD)/tests
	$(CC) $(CSTD) $(WARN) $(OPT) $(DEFS) -I. -I../tests $< $(LIBOBJ) -o $@

test: $(BIN) $(TESTBIN)
	@set -e; for t in $(TESTBIN); do $$t; done; echo "all tests passed"

install: $(BIN)
	install -d $(DESTDIR)$(PREFIX)/bin
	install -m 0755 $(BIN) $(DESTDIR)$(PREFIX)/bin/lx
	install -d $(DESTDIR)$(PREFIX)/share/man/man1
	install -m 0644 ../documentation/lx.1 $(DESTDIR)$(PREFIX)/share/man/man1/lx.1

clean:
	rm -rf $(BUILD)

.PHONY: all test install clean
